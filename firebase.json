{
  "firestore": {
    "database": "(default)",
    "location": "asia-northeast3",
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "hosting": {
    "public": "public",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/dashboard",
        "destination": "/dashboard.html"
      },
      {
        "source": "/dashboard/**",
        "destination": "/dashboard.html"
      },
      {
        "source": "/games/mole",
        "destination": "/games/mole/index.html"
      },
      {
        "source": "/games/mole/**",
        "destination": "/games/mole/index.html"
      },
      {
        "source": "/games/runner",
        "destination": "/games/runner/index.html"
      },
      {
        "source": "/games/runner/**",
        "destination": "/games/runner/index.html"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
